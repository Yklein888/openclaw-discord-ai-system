# ════════════════════════════════════════
# OpenClaw v3.0 AI System — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git!
# ════════════════════════════════════════

# ─── Discord Configuration ───────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=REPLACE_WITH_YOUR_GUILD_ID
MY_DISCORD_USER_ID=REPLACE_WITH_YOUR_USER_ID

# ─── Gateway Configuration ───────────────────────────────────────────
GATEWAY_URL=http://localhost:4001
MAX_AGENT_ITERATIONS=12

# ─── Redis Configuration ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LiteLLM Configuration ──────────────────────────────────────────
LITELLM_MASTER_KEY=sk-litellm-master-2026

# ─── Groq API Keys (9 keys for load balancing) ─────────────────────
GROQ_KEY_1=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_2=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_3=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_4=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_5=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_6=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_7=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_8=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_KEY_9=REPLACE_WITH_YOUR_GROQ_KEY

# ─── Cerebras API Keys (4 keys for load balancing) ──────────────────────
CEREBRAS_KEY_1=REPLACE_WITH_YOUR_CEREBRAS_KEY
CEREBRAS_KEY_2=REPLACE_WITH_YOUR_CEREBRAS_KEY
CEREBRAS_KEY_3=REPLACE_WITH_YOUR_CEREBRAS_KEY
CEREBRAS_KEY_4=REPLACE_WITH_YOUR_CEREBRAS_KEY

# ─── Gemini API Keys (5 keys for embeddings) ──────────────────────
GEMINI_KEY_1=your_gemini_key_here
GEMINI_KEY_2=your_gemini_key_here
GEMINI_KEY_3=your_gemini_key_here
GEMINI_KEY_4=your_gemini_key_here
GEMINI_KEY_5=your_gemini_key_here

# ─── GitHub Integration ───────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Notion Integration ────────────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_INBOX_DB=your_notion_database_id

# ─── Kilo CLI Configuration ───────────────────────────────────────────
KILO_BIN=/usr/local/bin/kilo
KILO_WORK_DIR=/home/ubuntu