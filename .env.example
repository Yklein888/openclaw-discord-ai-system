# ════════════════════════════════════════
# OpenClaw AI System — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git!
# ════════════════════════════════════════

# Discord
DISCORD_TOKEN=your_discord_bot_token_here

# Gemini API keys (get 5 free keys at aistudio.google.com)
GEMINI_KEY_1=AIza...
GEMINI_KEY_2=AIza...
GEMINI_KEY_3=AIza...
GEMINI_KEY_4=AIza...
GEMINI_KEY_5=AIza...

# GitHub Personal Access Token (repo scope)
GITHUB_TOKEN=ghp_...

# Notion Integration Token + Database IDs
NOTION_TOKEN=secret_...
NOTION_INBOX_DB=your_notion_database_id
